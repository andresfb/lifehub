includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon
    - phpstan-baseline.neon

parameters:
    treatPhpDocTypesAsCertain: false

    paths:
        - app
        - bootstrap/app.php
        - public
        - routes

    level: 6

    tmpDir: /tmp/phpstan
