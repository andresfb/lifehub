{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "jcodemunch-mcp": {
            "command": "uvx",
            "args": [
                "jcodemunch-mcp"
            ]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "n8n-mcp": {
          "type": "http",
          "url": "http://localhost:5678/mcp-server/http",
          "headers": {
                "Authorization": "Bearer ${N8N_MCP_TOKEN}"
            }
        }
    }
}
