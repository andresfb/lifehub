{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "andresfb/lifehub",
    "type": "project",
    "description": "API for the Personal Everything App",
    "keywords": ["laravel", "api", "rest", "fortify", "sanctum"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "dedoc/scramble": "^0.12|^0.13",
        "dyrynda/laravel-cascade-soft-deletes": "^4.6",
        "grazulex/laravel-apiroute": "^2.0",
        "laravel/ai": "^0.4.5",
        "laravel/fortify": "^1.36",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.45",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^11.1",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.32",
        "nunomaduro/essentials": "^1.2",
        "nwidart/laravel-modules": "^13.0",
        "spatie/browsershot": "^5.2",
        "spatie/laravel-data": "*",
        "spatie/laravel-medialibrary": "*",
        "spatie/laravel-permission": "*",
        "spatie/laravel-query-builder": "*",
        "spatie/laravel-responsecache": "^8.3",
        "spatie/laravel-sluggable": "^3.8",
        "spatie/laravel-tags": "^4.11",
        "square1/laravel-idempotency": "^13.0",
        "typesense/typesense-php": "^6.0"
    },
    "require-dev": {
        "deployer/deployer": "^7.5",
        "driftingly/rector-laravel": "^2.2",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "rector/rector": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan horizon\" \"php artisan pail --timeout=0\" --names=server,horizon,logs --kill-others"
        ],
        "rector": "rector",
        "lint": "pint",
        "test:rector": "rector --dry-run",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse --ansi --memory-limit=2G",
        "test:unit": "pest --colors=always --parallel",
        "test:coverage": "pest --colors=always --parallel --coverage --exactly=100",
        "test:type-coverage": "pest --type-coverage --min=100",
        "test": [
            "@php artisan config:clear --ansi",
            "@test:type-coverage",
            "@test:rector",
            "@test:lint",
            "@test:types",
            "@test:unit"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        },
        "platform": {
            "php": "8.3.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
